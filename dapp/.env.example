# Arc Testnet RPC
VITE_ARC_RPC_URL=https://rpc.testnet.arc.network

# Deployed SimplyVest contract address (fill after deployment)
VITE_SIMPLY_VEST_ADDRESS=

# Privy app ID (from https://dashboard.privy.io)
VITE_PRIVY_APP_ID=

# E2E test mode (set to "true" to bypass Privy auth)
VITE_DEV_AUTH_BYPASS=false

# API URL (Cloudflare Worker)
VITE_API_URL=https://api.simplyvest.xyz
